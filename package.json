		"@types/eslint": "^9.6.1",
		"autoprefixer": "^10.4.27",
		"eslint": "^9.12.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.44.1",
		"globals": "^17.4.0",
		"postcss": "^8.4.47",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "5.54.0",
		"svelte-check": "^4.4.5",
		"tailwind-merge": "^2.5.3",
		"tailwindcss": "^3.4.13",
